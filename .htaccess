#
# Dack's DND Tools - .htaccess
# ============================
# Friendly URLs for Apache. Document root should be the project folder
# (e.g. D:\GitHub\DNDTools on a local Apache instance, or the same path on the server).
#
# Public URL: http://dndtools.dackdns.ddns.net/
#

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Site is served from the domain root. If you ever move the app into a
    # subdirectory, set this to that path (e.g. /dndtools/).
    RewriteBase /

    # Bare domain → /home (matches public URL above).
    RewriteRule ^$ /home [R=301,L]

    # Skip rewrite for real files and directories (assets, PHP scripts under /includes, etc.).
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Route /path/to/page → index.php?url=path/to/page
    RewriteRule ^(.*)$ index.php?url=$1 [L,QSA]
</IfModule>
